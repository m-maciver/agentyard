# AgentYard Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── Database ──────────────────────────────────────────────────────────────────
# SQLite (local dev — no setup required)
DATABASE_URL=sqlite+aiosqlite:///./agentyard.db

# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agentyard

# ─── Redis (for background job queue via arq) ──────────────────────────────────
REDIS_URL=redis://localhost:6379
# Production: redis://:password@your-redis-host:6379

# ─── LNBits (Lightning payments) ───────────────────────────────────────────────
# Your LNBits instance URL
LNBITS_URL=https://demo.lnbits.com
# Replace with your own LNBits instance in production

# Escrow wallet — holds sats during job execution
LNBITS_ESCROW_WALLET_ADMINKEY=your_escrow_wallet_admin_key_here
LNBITS_ESCROW_WALLET_INKEY=your_escrow_wallet_invoice_key_here

# Platform fee wallet — receives the 12% platform fee
LNBITS_FEE_WALLET_ADMINKEY=your_fee_wallet_admin_key_here

# Stake wallet — holds agent reputation stakes
LNBITS_STAKE_WALLET_ADMINKEY=your_stake_wallet_admin_key_here

# Master admin key — used by skill to create per-agent sub-wallets
# Set to your LNbits instance admin key (umbrel.local:3007 or hosted)
LNBITS_ADMIN_KEY=your_lnbits_admin_key_here

# Set LIGHTNING_STUB=true to skip real LNbits calls (dev/test mode)
# LIGHTNING_STUB=true

# Webhook secret for verifying LNBits payment callbacks
LNBITS_WEBHOOK_SECRET=change_this_to_a_random_secret

# ─── GitHub OAuth ──────────────────────────────────────────────────────────────
# Register your OAuth app at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
# Replace with real secret from github.com/settings/developers
GITHUB_CLIENT_SECRET=your_secret_here
GITHUB_CALLBACK_URL=https://agentyard-backend.up.railway.app/auth/github/callback
FRONTEND_URL=https://frontend-xi-three-92.vercel.app

# ─── Authentication ────────────────────────────────────────────────────────────
# IMPORTANT: Generate a strong random secret for production
# Python: import secrets; print(secrets.token_hex(32))
JWT_SECRET=dev_jwt_secret_change_in_production_use_secrets_token_hex_32

# JWT expiry in hours (default: 24)
JWT_EXPIRY_HOURS=24

# JWT algorithm (default: HS256)
JWT_ALGORITHM=HS256

# ─── Platform Settings ─────────────────────────────────────────────────────────
# Platform fee rate (0.12 = 12%)
PLATFORM_FEE_RATE=0.12

# AgentYard webhook secret for verifying internal callbacks
AGENTYARD_WEBHOOK_SECRET=change_this_to_a_random_secret

# ─── Admin ─────────────────────────────────────────────────────────────────────
# Admin user email (created on first startup)
ADMIN_EMAIL=admin@agentyard.dev

# Discord webhook for admin alerts (optional)
# ADMIN_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# Admin API key — used for privileged endpoints
# IMPORTANT: Change this in production
ADMIN_API_KEY=dev_admin_key_change_in_production

# ─── Application ───────────────────────────────────────────────────────────────
# Environment: development | staging | production
APP_ENV=development

# Debug mode: true in dev, false in production
DEBUG=true
