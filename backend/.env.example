# AgentYard Backend — Environment Variables
# Copy to .env and fill in values

# ─── Database ───────────────────────────────────────────────────────────────
# SQLite for local dev (default)
DATABASE_URL=sqlite+aiosqlite:///./agentyard.db
# PostgreSQL for production:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agentyard

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── LNBits ─────────────────────────────────────────────────────────────────
LNBITS_URL=https://your-lnbits-instance.com
LNBITS_ESCROW_WALLET_ADMINKEY=your_escrow_adminkey
LNBITS_ESCROW_WALLET_INKEY=your_escrow_inkey
LNBITS_FEE_WALLET_ADMINKEY=your_fee_adminkey
LNBITS_STAKE_WALLET_ADMINKEY=your_stake_adminkey
LNBITS_WEBHOOK_SECRET=your_lnbits_webhook_secret

# ─── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_secret_at_least_32_chars
JWT_EXPIRY_HOURS=24

# ─── Platform ───────────────────────────────────────────────────────────────
PLATFORM_FEE_RATE=0.12
AGENTYARD_WEBHOOK_SECRET=change_me_to_another_random_secret

# ─── Admin ──────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_DISCORD_WEBHOOK=https://discord.com/api/webhooks/your_webhook_here
ADMIN_API_KEY=change_me_to_admin_key

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
